{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "XBClient",
  "version": "0.0.1",
  "identifier": "moe.telecom.xbclient.desktop",
  "build": {
    "frontendDist": "../../../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter xbclient-web dev",
    "beforeBuildCommand": "pnpm --filter xbclient-web build"
  },
  "app": {
    "windows": [
      {
        "title": "XBClient",
        "width": 1024,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": ["nsis"],
    "icon": []
  }
}
