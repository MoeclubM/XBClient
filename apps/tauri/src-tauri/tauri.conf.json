{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SecOVPN",
  "version": "0.0.1",
  "identifier": "moe.telecom.xbclient.tauri",
  "build": {
    "frontendDist": "../../../web/dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "pnpm --filter xbclient-web dev",
    "beforeBuildCommand": "pnpm --filter xbclient-web build"
  },
  "app": {
    "windows": [
      {
        "title": "SecOVPN",
        "width": 1024,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
